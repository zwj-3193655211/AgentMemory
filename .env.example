# AgentMemory Environment Configuration
# Copy this file to .env and modify as needed

# Java Environment (REQUIRED)
JAVA_HOME=D:\JDK\jdk_21
MAVEN_HOME=D:\apache-maven-3.9.11

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5500
DATABASE_NAME=agentmemory
DATABASE_USER=agentmemory
DATABASE_PASSWORD=agentmemory123

# SQLite Path (for migration scripts)
SQLITE_PATH=~/.agentmemory/data/agentmemory.db

# Service Ports
BACKEND_PORT=8080
FRONTEND_PORT=5173
EMBEDDING_PORT=8100

# Agent History Paths
QWEN_PROJECTS_PATH=~/.qwen/projects
CLAUDE_PROJECTS_PATH=~/.claude/projects

# Ollama Configuration
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b

# Frontend Configuration
VITE_API_BASE=http://localhost:8080/api
VITE_EMBED_BASE=http://localhost:8100
